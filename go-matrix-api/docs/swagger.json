{
    "swagger": "2.0",
    "info": {
        "description": "API for matrix rotation and QR factorization",
        "title": "Interseguro Matrix API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {
            "name": "API Support",
            "email": "your.email@example.com"
        },
        "license": {
            "name": "Apache 2.0",
            "url": "http://www.apache.org/licenses/LICENSE-2.0.html"
        },
        "version": "1.0"
    },
    "basePath": "/api",
    "paths": {
        "/auth/token": {
            "get": {
                "description": "Generates a valid JWT token valid for 24h for testing purposes.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Auth"
                ],
                "summary": "Generate an auth token",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/matrix": {
            "post": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Rotates a matrix, performs QR factorization, and retrieves statistics from Node.js API",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Matrix"
                ],
                "summary": "Process a matrix",
                "parameters": [
                    {
                        "description": "Matrix data",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/domain.MatrixRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/domain.BaseResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/domain.BaseResponse"
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/domain.BaseResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "domain.BaseResponse": {
            "type": "object",
            "properties": {
                "data": {
                    "$ref": "#/definitions/domain.MatrixResponse"
                },
                "error": {
                    "type": "string",
                    "example": "matrix cannot be empty"
                },
                "success": {
                    "type": "boolean",
                    "example": true
                }
            }
        },
        "domain.MatrixRequest": {
            "type": "object",
            "required": [
                "matrix"
            ],
            "properties": {
                "matrix": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "number",
                            "format": "float64"
                        }
                    }
                }
            }
        },
        "domain.MatrixResponse": {
            "type": "object",
            "properties": {
                "original_matrix": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "number",
                            "format": "float64"
                        }
                    }
                },
                "qr_factorization": {
                    "$ref": "#/definitions/domain.QRFactorization"
                },
                "rotated_matrix": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "number",
                            "format": "float64"
                        }
                    }
                },
                "statistics": {
                    "$ref": "#/definitions/domain.NodeStatistics"
                }
            }
        },
        "domain.NodeStatistics": {
            "type": "object",
            "properties": {
                "average": {
                    "type": "number",
                    "example": 0.45
                },
                "is_diagonal": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "boolean"
                    },
                    "example": {
                        "Q": false,
                        "R": false
                    }
                },
                "max_value": {
                    "type": "number",
                    "example": 6
                },
                "min_value": {
                    "type": "number",
                    "example": -7.81
                },
                "total_sum": {
                    "type": "number",
                    "example": 2.56
                }
            }
        },
        "domain.QRFactorization": {
            "type": "object",
            "properties": {
                "Q": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "number",
                            "format": "float64"
                        }
                    }
                },
                "R": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": {
                            "type": "number",
                            "format": "float64"
                        }
                    }
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "description": "Escribe \"Bearer \" seguido de tu token JWT.",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}